APP_NAME=Construction Budget Agent v3
APP_VERSION=3.0.0
BACKEND_PORT=8000
FRONTEND_PORT=80
VITE_API_BASE_URL=/api
AUTH_SECRET=change-this-secret-before-deploy
AUTH_TOKEN_TTL_SECONDS=43200
TZ=Asia/Yakutsk
# --- ИИ-заключение (OpenAI) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_SECONDS=90
# --- Прод-настройки ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOW_PUBLIC_GENERATE=true
RATE_LIMIT_GENERATE_PER_HOUR=60
RATE_LIMIT_AI_PER_HOUR=20
# --- Оплата (ЮKassa). Без ключей действует режим «оплата по счёту» ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
BILLING_RETURN_URL=https://your-domain/billing
