FROM node:22-alpine AS frontend-build

WORKDIR /app/frontend

ARG VITE_API_BASE_URL=/api
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}

COPY frontend/package*.json ./
RUN npm ci

COPY frontend ./
RUN npm run build

FROM python:3.12-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV AUTH_TOKEN_TTL_SECONDS=43200

RUN apt-get update \
    && apt-get install -y --no-install-recommends nginx gettext-base ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY backend ./backend
COPY main.py app.py pytest.ini README.md users.example.json ./
COPY --from=frontend-build /app/frontend/dist /app/frontend/dist
COPY render/nginx.conf.template /etc/nginx/templates/default.conf.template
COPY render/start_render.sh /app/start_render.sh

RUN mkdir -p backend/storage/projects backend/storage/outputs backend/storage/uploads \
    && chmod +x /app/start_render.sh

CMD ["/app/start_render.sh"]
